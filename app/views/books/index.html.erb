<body>
  <p id="notice"></p>
  <h1>Books</h1>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Body</th>
          <th colspan="3"></th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
        <div class= "book-body">
          <tr class= "book-row">
            <td><%= book.title %></td>
            <td><%= book.body %></td>
            <td>
              <%= link_to "Show", book_path(book.id) %>
            </td>
            <td>
              <%= link_to "Edit", book_path(book.id) %>
            </td>
            <td>
              <%= link_to "Destroy", book_path(book.id) %>
            </td>
          </tr>
        </div>
      </tbody>
      <% end %>
    </table>

  <h2>New book</h2>
  <form>
    <%= form_with model:@book, local:true do |f| %>
      <h4>Title</h4>
      <%= f.text_field :title %>
      <h4>Body</h4>
      <%= f.text_area :body %>

      <%= f.submit'Create Book' %>
    <% end %>
  </form>
</body>